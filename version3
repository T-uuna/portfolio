import sys
import os
import re
from PySide6.QtWidgets import QApplication, QWidget, QPushButton, QVBoxLayout, QLineEdit, QHBoxLayout, QLabel, QComboBox
from PySide6.QtCore import Qt
import hou

class SceneVersionSave(QWidget):
    def __init__(self):
        super().__init__()
        
        self.base_path = "C:/포폴"
        self.departments = ["부서1", "부서2", "부서3"]
        self.setup_directories()

        self.setWindowTitle("Houdini Save Tool")
        self.resize(300, 200)

        layout = QVBoxLayout()

        layout.addWidget(QLabel("Select Department:"))
        self.dept_combo = QComboBox()
        self.dept_combo.addItems(self.departments)
        layout.addWidget(self.dept_combo)

        layout.addWidget(QLabel("Custom File Name:"))
        self.name_input = QLineEdit()
        self.name_input.setPlaceholderText("Enter base name...")
        layout.addWidget(self.name_input)

        btn_layout = QHBoxLayout()
        self.auto_save_btn = QPushButton("Save Version (Auto)")
        self.auto_save_btn.clicked.connect(self.save_version_auto)
        btn_layout.addWidget(self.auto_save_btn)

        self.custom_save_btn = QPushButton("Save Custom w/ Version")
        self.custom_save_btn.clicked.connect(self.save_version_custom)
        btn_layout.addWidget(self.custom_save_btn)

        layout.addLayout(btn_layout)
        self.setLayout(layout)

    def setup_directories(self):
        for dept in self.departments:
            target_dir = os.path.join(self.base_path, dept).replace("\\", "/")
            if not os.path.exists(target_dir):
                os.makedirs(target_dir, exist_ok=True)

    def get_target_directory(self):
        return os.path.join(self.base_path, self.dept_combo.currentText()).replace("\\", "/")

    def get_global_next_version(self, directory):
        versions = [0]
        if not os.path.exists(directory):
            return 1
            
        for f in os.listdir(directory):
            match = re.search(r'_v(\d+)', f)
            if match:
                versions.append(int(match.group(1)))
                
        return max(versions) + 1

    def save_version_auto(self):
        directory = self.get_target_directory()
        current_path = hou.hipFile.path()
        filename = os.path.basename(current_path)
        
        if filename == "untitled.hip":
            base_name = "work"
        else:
            base_name = filename.split(".")[0].split("_v")[0]

        version = self.get_global_next_version(directory)
        new_name = f"{base_name}_v{version:03d}.hip"
        new_full_path = os.path.join(directory, new_name).replace("\\", "/")

        hou.hipFile.save(file_name=new_full_path)
        print(f"Auto Saved (Global Version): {new_full_path}")

    def save_version_custom(self):
        base_name = self.name_input.text().strip()
        if not base_name:
            hou.ui.displayMessage("Please enter a name!")
            return

        directory = self.get_target_directory()
        version = self.get_global_next_version(directory)
        new_name = f"{base_name}_v{version:03d}.hip"
        
        new_full_path = os.path.join(directory, new_name).replace("\\", "/")
        hou.hipFile.save(file_name=new_full_path)
        print(f"Custom Saved (Global Version): {new_full_path}")

app = QApplication.instance()
if not app:
    app = QApplication(sys.argv)

window = SceneVersionSave()
window.setParent(hou.qt.mainWindow(), Qt.Window)
window.show()
