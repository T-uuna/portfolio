import sys
import os
from PySide6.QtWidgets import QApplication, QWidget, QPushButton, QVBoxLayout, QLineEdit, QHBoxLayout, QLabel
from PySide6.QtCore import Qt
import hou

class SceneVersionSave(QWidget):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Houdini Save Tool")
        self.resize(300, 150)

        layout = QVBoxLayout()
        layout.addWidget(QLabel("Custom File Name:"))
        
        self.name_input = QLineEdit()
        self.name_input.setPlaceholderText("Enter file name here...")
        layout.addWidget(self.name_input)

        btn_layout = QHBoxLayout()
        self.auto_save_btn = QPushButton("Save Version (Auto)")
        self.auto_save_btn.clicked.connect(self.save_version_auto)
        btn_layout.addWidget(self.auto_save_btn)

        self.custom_save_btn = QPushButton("Save Custom")
        self.custom_save_btn.clicked.connect(self.save_version_custom)
        btn_layout.addWidget(self.custom_save_btn)

        layout.addLayout(btn_layout)
        self.setLayout(layout)

    def get_next_version(self, directory, base_name):
        versions = [0]
        if not os.path.exists(directory):
            return 1
        for f in os.listdir(directory):
            if f.startswith(base_name) and "_v" in f:
                try:
                    v_part = f.split("_v")[-1].split(".")[0]
                    versions.append(int(v_part))
                except (ValueError, IndexError):
                    pass
        return max(versions) + 1

    def save_version_auto(self):
        current_path = hou.hipFile.path()
        directory = os.path.dirname(current_path)
        filename = os.path.basename(current_path)
        
        if filename == "untitled.hip":
            base_name = "work"
        else:
            base_name = filename.split(".")[0].split("_v")[0]

        version = self.get_next_version(directory, base_name)
        new_name = f"{base_name}_v{version:03d}.hip"
        new_full_path = os.path.join(directory, new_name)

        hou.hipFile.save(file_name=new_full_path)
        print(f"Auto Saved: {new_full_path}")

    def save_version_custom(self):
        custom_name = self.name_input.text().strip()
        if not custom_name:
            hou.ui.displayMessage("Please enter a name!")
            return

        current_path = hou.hipFile.path()
        directory = os.path.dirname(current_path)
        if not custom_name.endswith(".hip"):
            custom_name += ".hip"
            
        new_full_path = os.path.join(directory, custom_name)
        hou.hipFile.save(file_name=new_full_path)
        print(f"Custom Saved: {new_full_path}")
        self.name_input.clear()

app = QApplication.instance()
if not app:
    app = QApplication(sys.argv)

window = SceneVersionSave()
window.setParent(hou.qt.mainWindow(), Qt.Window)
window.show()
